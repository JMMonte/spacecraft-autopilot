{
  "name": "@space/simulator",
  "version": "1.0.0",
  "description": "A Three.js space simulator with React UI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean-start": "rm -rf node_modules .vite dist && pnpm install && pnpm run dev",
    "check:ts": "tsc --noEmit --pretty false",
    "validate": "pnpm run test && pnpm run build",
    "test:physics": "node tools/collision-check.mjs",
    "test:ap": "node --import tsx tools/tests/autopilot.test.ts",
    "test:traj": "node --import tsx tools/tests/trajectory.test.ts",
    "test:unit": "node --import tsx --test $(find tests/unit -name '*.test.ts' -print)",
    "test:integration": "node --import tsx --test $(find tests/integration -name '*.test.ts' -print)",
    "test:architecture": "node --import tsx --test $(find tests/architecture -name '*.test.ts' -print)",
    "test": "pnpm run check:ts && pnpm run test:unit && pnpm run test:integration && pnpm run test:architecture",
    "list:unused": "node tools/list-unused.mjs",
    "tune": "node --import tsx tools/autopilot-tuner/index.ts",
    "tune:quick": "node --import tsx tools/autopilot-tuner/index.ts -- --mode test --scenarios corridor,slalom",
    "tune:optimize": "node --import tsx tools/autopilot-tuner/index.ts -- --mode optimize --method adaptive --iterations 50 -v",
    "tune:full": "node --import tsx tools/autopilot-tuner/index.ts -- --mode test --engine full --objective fuel -v",
    "tune:optimize:full": "node --import tsx tools/autopilot-tuner/index.ts -- --mode optimize --engine full --objective fuel --method adaptive --iterations 50 -v",
    "tune:visualize": "node --import tsx tools/autopilot-tuner/visualize-results.ts"
  },
  "author": "Joao Montenegro",
  "license": "ISC",
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.16.0",
  "dependencies": {
    "@andersonmancini/lens-flare": "^1.0.1",
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/postcss": "^4.2.0",
    "lucide-react": "^0.574.0",
    "mathjs": "^15.1.1",
    "ml-matrix": "^6.12.1",
    "postprocessing": "^6.38.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-draggable": "^4.5.0",
    "stats.js": "^0.17.0",
    "three": "^0.183.0",
    "three-subdivide": "^1.1.5"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
