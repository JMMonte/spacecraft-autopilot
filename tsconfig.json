{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    // Ensure React DOM JSX types are loaded in editors even if TS server
    // doesn't auto-detect dependency types
    "types": ["react", "react-dom", "node", "vite/client"],

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path aliases — keep in sync with vite.config.ts resolve.alias */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@config/*": ["src/config/*"],
      "@controllers/*": ["src/controllers/*"],
      "@core/*": ["src/core/*"],
      "@debug/*": ["src/debug/*"],
      "@domain/*": ["src/domain/*"],
      "@effects/*": ["src/effects/*"],
      "@helpers/*": ["src/helpers/*"],
      "@hooks/*": ["src/hooks/*"],
      "@objects/*": ["src/objects/*"],
      "@physics/*": ["src/physics/*"],
      "@scenes/*": ["src/scenes/*"],
      "@shaders/*": ["src/shaders/*"],
      "@state/*": ["src/state/*"],
      "@styles/*": ["src/styles/*"],
      "@types/*": ["src/types/*"],
      "@utils/*": ["src/utils/*"],
      "@workers/*": ["src/workers/*"],
      "three/examples/jsm/*": ["node_modules/three/examples/jsm/*"]
    },
    
    /* Allow JavaScript files */
    "allowJs": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "tools"],
  "references": [{ "path": "./tsconfig.node.json" }]
} 
